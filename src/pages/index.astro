---
import Base from '../layouts/Base.astro';
import { getDB } from '../lib/db';

const db = getDB(Astro.locals);
const states = await db
  .prepare('SELECT name, slug, abbreviation FROM states ORDER BY name')
  .all<{ name: string; slug: string; abbreviation: string }>();
---

<Base title="US Zoning Codes & Permitted Uses | ZoningBase">
  <!-- Hero -->
  <section class="bg-brand-950 text-text-inverse">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight max-w-3xl">
        US Zoning Codes, <span class="text-brand-400">Standardized</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-brand-200 max-w-2xl leading-relaxed">
        Every zone code, development standard, and permitted use across American cities — normalized into one searchable platform built for CRE professionals.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="/#states"
          class="inline-flex items-center justify-center px-6 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors"
        >
          Browse by State
        </a>
        <a
          href="/about/"
          class="inline-flex items-center justify-center px-6 py-3 border border-brand-600 text-brand-200 hover:bg-brand-800 font-semibold rounded-lg transition-colors"
        >
          How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Value props -->
  <section class="py-16 sm:py-20 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center">Built for Commercial Real Estate</h2>
      <p class="mt-3 text-text-secondary text-center max-w-2xl mx-auto">
        Stop wasting hours digging through municipal PDFs. ZoningBase normalizes zoning ordinances into structured, comparable data.
      </p>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="bg-surface rounded-xl border border-border p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg">Development Standards</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Max height, FAR, lot size, setbacks, impervious cover, and parking requirements — all in one place.
          </p>
        </div>

        <div class="bg-surface rounded-xl border border-border p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg">Permitted Uses</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Know exactly what's allowed in each zone — residential, commercial, industrial, mixed-use, and conditional uses.
          </p>
        </div>

        <div class="bg-surface rounded-xl border border-border p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg">Every US City</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            From Austin to Anchorage. We're building the most comprehensive zoning database in America, one city at a time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- States -->
  <section id="states" class="py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold">Browse by State</h2>
      <p class="mt-2 text-text-secondary">Select a state to explore its zoning codes.</p>
      {states.results.length > 0 ? (
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {states.results.map((s) => (
            <a
              href={`/${s.slug}/`}
              class="flex items-center gap-2 px-4 py-3 bg-surface rounded-lg border border-border hover:border-brand-400 hover:shadow-sm transition-all"
            >
              <span class="text-xs font-mono text-text-muted">{s.abbreviation}</span>
              <span class="font-medium text-sm">{s.name}</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="mt-8 p-12 border-2 border-dashed border-border rounded-xl text-center text-text-muted">
          State data is being loaded. Check back soon.
        </div>
      )}
    </div>
  </section>
</Base>

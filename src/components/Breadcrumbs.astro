---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const schemaItems = crumbs.map((crumb, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: crumb.label,
  ...(crumb.href ? { item: new URL(crumb.href, Astro.site).href } : {}),
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<nav aria-label="Breadcrumb" class="text-sm text-text-muted">
  <ol class="flex flex-wrap items-center gap-1">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="text-border">/</span>}
        {crumb.href ? (
          <a href={crumb.href} class="hover:text-brand-600 transition-colors">{crumb.label}</a>
        ) : (
          <span class="text-text-secondary">{crumb.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
